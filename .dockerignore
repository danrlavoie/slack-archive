# VCS + editor
.git
.gitignore
.vscode
.claude
.superpowers

# Node modules — always reinstalled inside image
node_modules
**/node_modules

# Build outputs — always rebuilt inside image
**/dist
**/out

# Existing data / backups / config from host
slack-archive/
data/
backups/
config/

# Test artifacts
test-results/
coverage/
**/*.log
.token

# Env files
.env
.env.*
!.env.example

# Docs (not needed at runtime — keeps layers small)
docs/
*.md
